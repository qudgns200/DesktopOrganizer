<Window x:Class="DesktopOrganizer.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:DesktopOrganizer.Views.Controls"
        Title="Desktop Organizer Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Left="0" Top="0"
        Topmost="True">

    <!--
        Root Grid has Background="Transparent" so it participates in hit testing,
        allowing the right-click context menu to open (F-004).
        Empty areas that are NOT over a ContainerControl are returned as
        HTTRANSPARENT by the WndProc hook, so left-clicks pass through to the desktop.
    -->
    <Grid x:Name="OverlayRoot"
          Background="Transparent"
          PreviewMouseRightButtonDown="OnPreviewMouseRightButtonDown">

        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="새 Container" Click="OnCreateContainerMenuClick"/>
            </ContextMenu>
        </Grid.ContextMenu>

        <!-- Container layer — absolute positioning via Canvas inside ItemsControl -->
        <ItemsControl ItemsSource="{Binding Containers}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas IsHitTestVisible="True"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left" Value="{Binding X}"/>
                    <Setter Property="Canvas.Top"  Value="{Binding Y}"/>
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <controls:ContainerControl/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Grid>
</Window>
