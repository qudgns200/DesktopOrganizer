<Window x:Class="DesktopOrganizer.Views.Dialogs.StyleEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:DesktopOrganizer.Views.Controls"
        Title="Container 스타일 변경"
        Width="580" Height="420"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:StringToBrushConverter         x:Key="StringToBrush"/>
        <conv:BoolToVisibilityConverter      x:Key="BoolToVis"/>
        <conv:DoubleToCornerRadiusConverter  x:Key="DblToCornerRadius"/>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="12"/>
            <ColumnDefinition Width="200"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Left: property editors ──────────────────────────── -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Background Color -->
                <TextBlock Text="배경 색상 (ARGB 16진수)" Margin="0,0,0,2"/>
                <TextBox Text="{Binding BackgroundColor, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,3"/>

                <!-- Background Opacity -->
                <TextBlock Text="{Binding BackgroundOpacity, StringFormat='배경 투명도  {0:P0}'}"
                           Margin="0,10,0,2"/>
                <Slider Value="{Binding BackgroundOpacity}" Minimum="0" Maximum="1"
                        TickFrequency="0.05" IsSnapToTickEnabled="False" SmallChange="0.05"/>

                <!-- Border Color -->
                <TextBlock Text="테두리 색상 (ARGB 16진수)" Margin="0,10,0,2"/>
                <TextBox Text="{Binding BorderColor, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,3"/>

                <!-- Border Thickness -->
                <TextBlock Text="{Binding BorderThickness, StringFormat='테두리 두께  {0:F1}'}"
                           Margin="0,10,0,2"/>
                <Slider Value="{Binding BorderThickness}" Minimum="0" Maximum="10"
                        TickFrequency="0.5" IsSnapToTickEnabled="False" SmallChange="0.5"/>

                <!-- Border Style -->
                <TextBlock Text="테두리 스타일" Margin="0,10,0,2"/>
                <ComboBox ItemsSource="{Binding BorderStyleOptions}"
                          SelectedItem="{Binding BorderStyle}"
                          Padding="4,3"/>

                <!-- Corner Radius -->
                <TextBlock Text="{Binding CornerRadius, StringFormat='모서리 둥글기  {0:F0}'}"
                           Margin="0,10,0,2"/>
                <Slider Value="{Binding CornerRadius}" Minimum="0" Maximum="40"
                        TickFrequency="2" IsSnapToTickEnabled="False" SmallChange="1"/>

                <!-- Show Title -->
                <CheckBox Content="제목 표시" IsChecked="{Binding ShowTitle}" Margin="0,10,0,0"/>

                <!-- Title Font Size -->
                <TextBlock Text="{Binding TitleFontSize, StringFormat='제목 글자 크기  {0:F0}'}"
                           Margin="0,10,0,2"/>
                <Slider Value="{Binding TitleFontSize}" Minimum="8" Maximum="24"
                        TickFrequency="1" IsSnapToTickEnabled="True" SmallChange="1"/>

                <!-- Title Font Color -->
                <TextBlock Text="제목 글자 색상 (ARGB 16진수)" Margin="0,10,0,2"/>
                <TextBox Text="{Binding TitleFontColor, UpdateSourceTrigger=PropertyChanged}"
                         Padding="4,3"/>
            </StackPanel>
        </ScrollViewer>

        <!-- ── Right: live preview ──────────────────────────────── -->
        <Border Grid.Column="2" Background="#FF1E1E1E" CornerRadius="4">
            <Grid>
                <TextBlock Text="미리보기" Foreground="#888888" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,8"/>

                <!-- Simulated container preview -->
                <Grid Margin="16,28,16,16" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <!-- Background fill -->
                    <Border Background="{Binding BackgroundColor, Converter={StaticResource StringToBrush}}"
                            Opacity="{Binding BackgroundOpacity}"
                            CornerRadius="{Binding CornerRadius, Converter={StaticResource DblToCornerRadius}}"/>
                    <!-- Border outline -->
                    <Border BorderBrush="{Binding BorderColor, Converter={StaticResource StringToBrush}}"
                            BorderThickness="{Binding BorderThickness}"
                            CornerRadius="{Binding CornerRadius, Converter={StaticResource DblToCornerRadius}}"/>
                    <!-- Title bar preview -->
                    <Border Background="#60000000" Height="26" VerticalAlignment="Top"
                            CornerRadius="{Binding CornerRadius, Converter={StaticResource DblToCornerRadius}}"
                            Visibility="{Binding ShowTitle, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Container 이름"
                                   Foreground="{Binding TitleFontColor, Converter={StaticResource StringToBrush}}"
                                   FontSize="{Binding TitleFontSize}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- ── Bottom: OK / Cancel ──────────────────────────────── -->
        <StackPanel Grid.Row="1" Grid.ColumnSpan="3"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="취소" Width="80" IsCancel="True" Click="OnCancelClick"/>
            <Button Content="확인" Width="80" Margin="8,0,0,0" IsDefault="True" Click="OnOkClick"/>
        </StackPanel>
    </Grid>
</Window>
